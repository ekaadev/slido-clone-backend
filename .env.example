# DATABASE CONFIGURATION
# When running postgres via docker compose (dev): use port 5433
# When running postgres natively: use port 5432
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=reisify
# disable | require | verify-full (use require or verify-full in production)
DATABASE_SSLMODE=disable

# JWT CONFIGURATION
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-32-char-min-secret

# REDIS CONFIGURATION
# When running redis via docker compose (dev): use port 6380
# When running redis natively: use port 6379
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_PASSWORD=

# CORS CONFIGURATION
# Comma-separated list of allowed origins (e.g. https://app.example.com,https://admin.example.com)
ALLOWED_ORIGINS=http://localhost:3000

# COOKIE CONFIGURATION
# Set to true in production (HTTPS). false allows cookies over plain HTTP (local dev).
COOKIE_SECURE=false
